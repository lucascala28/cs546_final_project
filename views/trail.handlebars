<main class="page">
  <h1 class="page-title">{{trail.name}}</h1>
  <p class="page-desc">{{trail.location}} • {{trail.type}} • {{trail.surface}} • {{toFixed2 trail.length}} mi • {{trail.difficulty}}</p>

  <div class="row">
    <form method="POST" action="/favorites/toggle/{{trail._id}}?returnTo=/trails/{{trail._id}}">
      <button class="btn {{#if isFavorited}}btn-dark{{else}}btn-outline{{/if}}" type="submit">
        {{#if isFavorited}}Favorited{{else}}Add to Favorites{{/if}}
      </button>
    </form>

    <a class="btn btn-dark" href="/reports/new?trailId={{trail._id}}">Create Report</a>
  </div>

  {{#if trail.geometry}}
  <section class="section">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <div id="trail-map"></div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
      const geo = {{{geometryJson}}};
      const map = L.map('trail-map');
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);
      const layer = L.geoJSON(geo, { style: { color: '#2d6a4f', weight: 3 } }).addTo(map);
      map.fitBounds(layer.getBounds(), { padding: [16, 16] });
    </script>
  </section>
  {{/if}}

  <section class="section">
    <h2 class="h2">Reports</h2>
    {{#if reports.length}}
      {{#each reports}}
        <div class="card">
          <div class="small">{{date}} • Severity: {{severity}} • by {{username}}</div>
          <p>{{description}}</p>
          {{#if attachments.length}}
            <div class="photos">
              {{#each attachments}}
                <a href="{{this}}" target="_blank" rel="noreferrer">
                  <img src="{{this}}" alt="Report attachment" />
                </a>
              {{/each}}
            </div>
          {{/if}}
        </div>
      {{/each}}
    {{else}}
      <p class="page-desc">No reports yet.</p>
    {{/if}}
  </section>

  <section class="section">
    <h2 class="h2">Comments</h2>
    <form class="card" method="POST" action="/trails/{{trail._id}}/comments">
      <label class="field">
        <span>Add a comment</span>
        <textarea name="content" rows="3" required minlength="1" maxlength="500"></textarea>
      </label>
      <button class="btn btn-dark" type="submit">Post</button>
    </form>

    {{#if comments.length}}
      {{#each comments}}
        <div class="card">
          <div class="small">{{date}} • {{username}}</div>
          <p>{{content}}</p>
        </div>
      {{/each}}
    {{else}}
      <p class="page-desc">No comments yet.</p>
    {{/if}}
  </section>
</main>

