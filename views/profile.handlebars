<main class="page">
  <h1 class="page-title">{{user.username}}</h1>
  <p class="page-desc">{{user.email}} • {{user.role}}</p>

  <section class="section">
    <h2 class="h2">Stats</h2>
    <div class="stats-row">
      <div class="stat-card">
        <span class="stat-number">{{user.milesHiked}}</span>
        <span class="stat-label">Miles Hiked</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{{reports.length}}</span>
        <span class="stat-label">Reports Submitted</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{{user.favoriteTrailIds.length}}</span>
        <span class="stat-label">Favorites</span>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="h2">Badges</h2>
    {{#if user.badges.length}}
      {{#each user.badges}}
        <span class="badge">{{this}}</span>
      {{/each}}
    {{else}}
      <p class="page-desc">No badges yet.</p>
    {{/if}}
  </section>

  <section class="section">
    <h2 class="h2">My Reports</h2>
    {{#if reports.length}}
      {{#each reports}}
        <a class="card card-link" href="/trails/{{trailId}}">
          <div class="small">{{date}} • Severity: {{severity}} • {{#if resolved}}Resolved{{else}}Open{{/if}}</div>
          <p>{{trailName}}</p>
          <p>{{description}}</p>
        </a>
      {{/each}}
    {{else}}
      <p class="page-desc">No reports submitted yet.</p>
    {{/if}}
  </section>

</main>


