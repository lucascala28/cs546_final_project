<main class="page">
  <h1 class="page-title">Trails</h1>

  <form class="search" method="GET" action="/trails">
    <input name="q" value="{{q}}" placeholder="Search trails by name…" maxlength="80" />
    <button class="btn btn-dark" type="submit">Search</button>
  </form>
  <button class="btn btn-dark" id="nearby-trails">Find trails near me</button>
  <label for="search-radius">Search radius</label>
  <select name="search-radius" id="search-radius">
    <option value="5">5 miles</option>
    <option value="10">10 miles</option>
    <option value="20">20 miles</option>
    <option value="50">50 miles</option>
  </select>

  <div class="grid">
    {{#if trails.length}}
    {{#each trails}}
    <a class="trail-card" href="/trails/{{_id}}">
      <div class="trail-name">{{name}}</div>
      <div class="trail-meta">{{location}} • {{type}} • {{surface}}</div>
      <div class="trail-meta">Length: {{toFixed2 length}} mi • Difficulty: {{difficulty}} • Status: {{status}}</div>
    </a>
    {{/each}}
    {{else}}
    <p class="page-desc">No trails found.</p>
    {{/if}}
  </div>
</main>